---
import DocsLayout from "../layouts/DocsLayout.astro";
import { getAllTypes } from "../lib/api-data";

const allTypes = getAllTypes();
const base = import.meta.env.BASE_URL;
---

<DocsLayout title="Home">
  <div class="max-w-3xl mx-auto">
    <!-- Hero -->
    <div class="text-center py-20">
      <div class="inline-flex items-center gap-2 rounded-full border border-accent/30 bg-accent/10 px-4 py-1.5 text-sm text-accent mb-6">
        <span class="bg-accent text-white text-xs font-bold px-1.5 py-0.5 rounded">s&</span>
        Community Documentation
      </div>
      <h1 class="text-5xl font-bold text-text mb-4">
        Welcome to s&amp;box <span class="text-accent">Community Docs</span>
      </h1>
      <p class="text-text-muted text-lg max-w-2xl mx-auto">
        A fast, searchable, and statically generated documentation site for the s&amp;box game engine.
        Built by the community, for the community.
      </p>
    </div>

    <!-- Cards -->
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      <a
        href={`${base}/api/`}
        class="group block rounded-xl border border-border bg-surface p-6 hover:border-accent/50 hover:bg-surface-hover transition-all"
      >
        <div class="flex items-center gap-3 mb-3">
          <div class="rounded-lg bg-accent/10 p-2.5">
            <svg class="h-5 w-5 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
            </svg>
          </div>
          <h2 class="text-lg font-semibold text-text group-hover:text-accent transition-colors">
            API Reference
          </h2>
        </div>
        <p class="text-sm text-text-muted leading-relaxed">
          Browse {allTypes.length.toLocaleString()} types, classes, structs, enums, and interfaces across the s&amp;box engine.
        </p>
        <div class="mt-4 flex items-center gap-1 text-sm text-accent">
          <span>Explore</span>
          <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
          </svg>
        </div>
      </a>

      <div class="group block rounded-xl border border-border/50 bg-surface/50 p-6 opacity-60">
        <div class="flex items-center gap-3 mb-3">
          <div class="rounded-lg bg-text-muted/10 p-2.5">
            <svg class="h-5 w-5 text-text-muted" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
            </svg>
          </div>
          <h2 class="text-lg font-semibold text-text-muted">
            Guides
          </h2>
        </div>
        <p class="text-sm text-text-muted leading-relaxed">
          Tutorials and guides for getting started with s&amp;box development.
        </p>
        <div class="mt-4 text-sm text-text-muted">
          Coming soon
        </div>
      </div>
    </div>
  </div>
</DocsLayout>
