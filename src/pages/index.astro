---
import "../styles/globals.css";
import { Icon } from "astro-icon/components";
import { Search } from "../components/Search";
import { getAllTypes } from "../lib/api-data";
import ThemeToggle from "../components/ThemeToggle.astro";
import ThemeScript from "../components/ThemeScript.astro";

const allTypes = getAllTypes();
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href={`${base}/favicon.svg`} />
    <title>s&box Community Docs</title>
    <meta name="description" content="Community documentation for the s&box game engine. API reference and development guides." />
    <meta property="og:title" content="s&box Community Docs" />
    <meta property="og:description" content="Community documentation for the s&box game engine." />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="s&box Community Docs" />
    <ThemeScript />
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebSite",
      name: "s&box Community Docs",
      url: "https://sbox.redeaglestudios.org",
      description: "Community documentation for the s&box game engine.",
    })} />
  </head>
  <body class="bg-background text-text">
    <!-- Header -->
    <header class="border-b border-border bg-background/80 backdrop-blur-sm">
      <div class="flex items-center justify-between px-4 h-14 max-w-5xl mx-auto">
        <a href={`${base}/`} class="flex items-center gap-2 font-bold text-accent hover:text-accent-hover transition-colors">
          <span class="bg-accent text-white text-xs font-bold px-1.5 py-0.5 rounded">s&</span>
          <span>Community Docs</span>
        </a>
        <div class="flex-1 max-w-md mx-4">
          <Search client:idle base={base} />
        </div>
        <div class="flex items-center gap-4 text-sm text-text-muted">
          <a href={`${base}/doc/`} class="hover:text-text transition-colors">Docs</a>
          <a href={`${base}/api/`} class="hover:text-text transition-colors">API</a>
          <ThemeToggle />
        </div>
      </div>
    </header>

    <main class="max-w-3xl mx-auto px-6">
      <!-- Hero -->
      <div class="text-center py-20">
        <h1 class="text-5xl font-bold text-text mb-4">
          Welcome to s&box <span class="text-accent">Community Docs</span>
        </h1>
        <p class="text-text-muted text-lg max-w-2xl mx-auto">
          A fast, searchable, and statically generated documentation site for the s&box game engine.
          Built by the community, for the community.
        </p>
      </div>

      <!-- Cards -->
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <a
          href={`${base}/api/`}
          class="group block rounded-xl border border-border bg-surface p-6 hover:border-accent/50 hover:bg-surface-hover transition-all"
        >
          <div class="flex items-center gap-3 mb-3">
            <div class="rounded-lg bg-accent/10 p-2.5">
              <Icon name="lucide:book-open" class="h-5 w-5 text-accent" />
            </div>
            <h2 class="text-lg font-semibold text-text group-hover:text-accent transition-colors">
              API Reference
            </h2>
          </div>
          <p class="text-sm text-text-muted leading-relaxed">
            Browse {allTypes.length.toLocaleString()} types, classes, structs, enums, and interfaces across the s&box engine.
          </p>
          <div class="mt-4 flex items-center gap-1 text-sm text-accent">
            <span>Explore</span>
            <Icon name="lucide:arrow-right" class="h-4 w-4" />
          </div>
        </a>

        <a
          href={`${base}/doc/`}
          class="group block rounded-xl border border-border bg-surface p-6 hover:border-accent/50 hover:bg-surface-hover transition-all"
        >
          <div class="flex items-center gap-3 mb-3">
            <div class="rounded-lg bg-accent/10 p-2.5">
              <Icon name="lucide:file-text" class="h-5 w-5 text-accent" />
            </div>
            <h2 class="text-lg font-semibold text-text group-hover:text-accent transition-colors">
              Guides
            </h2>
          </div>
          <p class="text-sm text-text-muted leading-relaxed">
            Tutorials and guides for getting started with s&box development.
          </p>
          <div class="mt-4 flex items-center gap-1 text-sm text-accent">
            <span>Read guides</span>
            <Icon name="lucide:arrow-right" class="h-4 w-4" />
          </div>
        </a>
      </div>

      <!-- Why link -->
      <div class="text-center mt-12">
        <a href={`${base}/why`} class="text-sm text-text-muted hover:text-accent transition-colors">
          Why does this site exist?
        </a>
      </div>
    </main>

    <!-- Footer -->
    <footer class="border-t border-border mt-16 py-8">
      <div class="max-w-3xl mx-auto px-6 flex flex-col sm:flex-row items-center justify-between gap-4 text-sm text-text-muted">
        <div class="flex items-center gap-2">
          <span>Made by</span>
          <a href="https://redeaglestudios.org" class="text-text hover:text-accent transition-colors font-medium" target="_blank" rel="noopener">
            Red Eagle Studios
          </a>
        </div>
        <div class="flex items-center gap-4">
          <a href="https://github.com/RedEagleStudios/sbox-docs" class="inline-flex items-center gap-1.5 hover:text-text transition-colors" target="_blank" rel="noopener">
            <Icon name="lucide:github" class="h-4 w-4" />
            GitHub
          </a>
          <ThemeToggle />
        </div>
      </div>
    </footer>
  </body>
</html>
