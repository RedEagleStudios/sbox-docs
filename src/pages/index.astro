---
import DocsLayout from "../layouts/DocsLayout.astro";
import { getNamespaces, getAllTypes } from "../lib/api-data";

const namespaces = getNamespaces();
const allTypes = getAllTypes();
const totalTypes = allTypes.length;
const totalMethods = allTypes.reduce((sum, t) => sum + (t.Methods?.filter(m => m.IsPublic)?.length ?? 0), 0);
const totalProperties = allTypes.reduce((sum, t) => sum + (t.Properties?.filter(p => p.IsPublic)?.length ?? 0), 0);
const base = import.meta.env.BASE_URL;

const cards = [
  {
    title: "API Reference",
    description: "Browse all types, methods, and properties across the s&box engine.",
    href: `${base}/api/Color`,
    icon: "book",
  },
  {
    title: "Classes",
    description: `${allTypes.filter(t => t.Group === "class").length} classes including components, systems, and utilities.`,
    href: `${base}/api/Sandbox.GameObject`,
    icon: "box",
  },
  {
    title: "Structs",
    description: `${allTypes.filter(t => t.Group === "struct").length} value types for math, colors, transforms and more.`,
    href: `${base}/api/Vector3`,
    icon: "layers",
  },
  {
    title: "Enums",
    description: `${allTypes.filter(t => t.Group === "enum").length} enumerations for configuration and state.`,
    href: `${base}/api/Sandbox.CollisionLayer`,
    icon: "list",
  },
];

const stats = [
  { label: "Types", value: totalTypes.toLocaleString() },
  { label: "Methods", value: totalMethods.toLocaleString() },
  { label: "Properties", value: totalProperties.toLocaleString() },
  { label: "Namespaces", value: namespaces.length.toString() },
];
---

<DocsLayout title="Home">
  <div class="max-w-4xl mx-auto">
    <!-- Hero -->
    <div class="text-center py-16">
      <div class="inline-flex items-center gap-2 rounded-full border border-accent/30 bg-accent/10 px-4 py-1.5 text-sm text-accent mb-6">
        <span class="bg-accent text-white text-xs font-bold px-1.5 py-0.5 rounded">s&</span>
        Community Documentation
      </div>
      <h1 class="text-5xl font-bold text-text mb-4">
        s&amp;box <span class="text-accent">API Reference</span>
      </h1>
      <p class="text-text-muted text-lg max-w-2xl mx-auto mb-8">
        A fast, searchable, and statically generated reference for the s&amp;box game engine API.
        Built because the official docs deserve better.
      </p>
      <div class="flex items-center justify-center gap-4">
        <a
          href={`${base}/api/Color`}
          class="inline-flex items-center gap-2 rounded-lg bg-accent px-5 py-2.5 text-sm font-medium text-white hover:bg-accent-hover transition-colors"
        >
          Browse API
          <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
          </svg>
        </a>
        <a
          href={`${base}/namespaces`}
          class="inline-flex items-center gap-2 rounded-lg border border-border bg-surface px-5 py-2.5 text-sm font-medium text-text hover:bg-surface-hover transition-colors"
        >
          All Namespaces
        </a>
      </div>
    </div>

    <!-- Stats -->
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-4 mb-12">
      {stats.map((stat) => (
        <div class="text-center rounded-xl border border-border bg-surface p-4">
          <div class="text-2xl font-bold text-accent">{stat.value}</div>
          <div class="text-sm text-text-muted">{stat.label}</div>
        </div>
      ))}
    </div>

    <!-- Feature Cards -->
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-12">
      {cards.map((card) => (
        <a
          href={card.href}
          class="group block rounded-xl border border-border bg-surface p-6 hover:border-accent/50 hover:bg-surface-hover transition-all"
        >
          <h2 class="text-lg font-semibold text-text group-hover:text-accent transition-colors mb-2">
            {card.title}
          </h2>
          <p class="text-sm text-text-muted leading-relaxed">
            {card.description}
          </p>
        </a>
      ))}
    </div>

    <!-- Popular types -->
    <div class="mb-12">
      <h2 class="text-xl font-semibold text-text mb-4">Popular Types</h2>
      <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-3">
        {["Color", "Vector3", "Angles", "BBox", "Sandbox.GameObject", "Sandbox.Component", "Sandbox.SceneTrace", "Sandbox.Sound"].map((name) => {
          const slug = name.replace(/</g, "(").replace(/>/g, ")").replace(/,/g, "_");
          return (
            <a
              href={`${base}/api/${slug}`}
              class="rounded-lg border border-border bg-surface px-4 py-3 text-sm text-text hover:border-accent/50 hover:text-accent transition-all"
            >
              <code>{name.split(".").pop()}</code>
            </a>
          );
        })}
      </div>
    </div>
  </div>
</DocsLayout>
