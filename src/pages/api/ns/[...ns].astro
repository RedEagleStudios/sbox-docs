---
import DocsLayout from "../../../layouts/DocsLayout.astro";
import { TypeBadge } from "../../../components/TypeBadge";
import { getNamespaces, namespaceLink, getTypeByFullName, stripXml } from "../../../lib/api-data";
import type { NamespaceGroup } from "../../../lib/types";

export function getStaticPaths() {
  const namespaces = getNamespaces();
  return namespaces.map((ns) => ({
    params: { ns: ns.namespace },
    props: { ns },
  }));
}

interface Props {
  ns: NamespaceGroup;
}

const { ns } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, "");

// Group types by kind
const groups = [
  { label: "Classes", types: ns.types.filter((t) => t.group === "class") },
  { label: "Structs", types: ns.types.filter((t) => t.group === "struct") },
  { label: "Enums", types: ns.types.filter((t) => t.group === "enum") },
  { label: "Interfaces", types: ns.types.filter((t) => t.group === "interface") },
].filter((g) => g.types.length > 0);

// Build breadcrumb parts
const nsParts = ns.namespace === "(global)" ? [] : ns.namespace.split(".");
---

<DocsLayout title={ns.namespace} currentNamespace={ns.namespace}>
  <div data-pagefind-body>
    <!-- Breadcrumb -->
    <div class="flex items-center gap-2 text-sm text-text-muted mb-6 flex-wrap">
      <a href={`${base}/api/`} class="hover:text-accent transition-colors">API</a>
      {nsParts.map((part, i) => {
        const path = nsParts.slice(0, i + 1).join(".");
        const isLast = i === nsParts.length - 1;
        return (
          <>
            <span>&rsaquo;</span>
            {isLast ? (
              <span class="text-text">{part}</span>
            ) : (
              <a href={namespaceLink(path)} class="hover:text-accent transition-colors">{part}</a>
            )}
          </>
        );
      })}
    </div>

    <!-- Header -->
    <div class="mb-8">
      <div class="flex items-center gap-3 mb-2">
        <span class="inline-flex items-center rounded-md border border-blue-500/30 bg-blue-500/10 px-2.5 py-0.5 text-xs font-medium text-blue-400">
          namespace
        </span>
        <h1 class="text-3xl font-bold text-accent">{ns.namespace}</h1>
      </div>
      <p class="text-text-muted">
        {ns.types.length} type{ns.types.length !== 1 ? "s" : ""}
      </p>
    </div>

    <!-- Type groups -->
    {groups.map((group) => (
      <section class="mb-8">
        <h2 class="text-xl font-semibold text-text mb-4 border-b border-border pb-2">{group.label}</h2>
        <div class="overflow-x-auto">
          <table class="w-full text-sm">
            <thead>
              <tr class="border-b border-border text-left text-text-muted">
                <th class="pb-2 pr-4 font-medium">Type</th>
                <th class="pb-2 pr-4 font-medium">Name</th>
                <th class="pb-2 font-medium">Description</th>
              </tr>
            </thead>
            <tbody>
              {group.types.map((t) => {
                const full = getTypeByFullName(t.fullName);
                const desc = full?.Documentation?.Summary ? stripXml(full.Documentation.Summary).slice(0, 120) : "";
                return (
                  <tr class="border-b border-border/50 hover:bg-surface-hover transition-colors">
                    <td class="py-2.5 pr-4">
                      <TypeBadge group={t.group} className="text-[9px] px-1 py-0" />
                    </td>
                    <td class="py-2.5 pr-4 whitespace-nowrap">
                      <a href={`${base}/api/${t.slug}`} class="text-accent hover:underline">{t.name}</a>
                    </td>
                    <td class="py-2.5 text-text-muted text-xs">{desc}</td>
                  </tr>
                );
              })}
            </tbody>
          </table>
        </div>
      </section>
    ))}
  </div>
</DocsLayout>
