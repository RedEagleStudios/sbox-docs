---
import DocsLayout from "../../layouts/DocsLayout.astro";
import { getNamespaceTree, getAllTypes } from "../../lib/api-data";
import type { NamespaceTreeNode } from "../../lib/types";

const tree = getNamespaceTree();
const totalTypes = getAllTypes().length;
const base = import.meta.env.BASE_URL.replace(/\/$/, "");

function countGroups(node: NamespaceTreeNode): Record<string, number> {
  const counts: Record<string, number> = {};
  function walk(n: NamespaceTreeNode) {
    for (const t of n.types) {
      counts[t.group] = (counts[t.group] || 0) + 1;
    }
    for (const c of n.children) walk(c);
  }
  walk(node);
  return counts;
}

const groupColors: Record<string, string> = {
  class: "text-blue-400",
  struct: "text-green-400",
  enum: "text-purple-400",
  interface: "text-yellow-400",
};
---

<DocsLayout title="API Reference">
  <div data-pagefind-body>
    <div class="mb-8">
      <h1 class="text-3xl font-bold text-accent mb-2">API Reference</h1>
      <p class="text-text-muted">
        {totalTypes} types across {tree.length} top-level namespaces
      </p>
    </div>

    <div class="space-y-6">
      {tree.map((root) => {
        const counts = countGroups(root);
        return (
          <div class="rounded-xl border border-border bg-surface p-5">
            <div class="flex items-center justify-between mb-3">
              <h2 class="text-lg font-semibold text-text">{root.name}</h2>
              <span class="text-xs text-text-muted">{root.totalTypes} types</span>
            </div>
            <div class="flex flex-wrap gap-2 text-xs mb-4">
              {Object.entries(counts).map(([group, count]) => (
                <span class={groupColors[group] ?? "text-text-muted"}>
                  {count} {group}{count > 1 ? (group === "class" ? "es" : "s") : ""}
                </span>
              ))}
            </div>

            {/* Child namespaces as sub-cards */}
            {root.children.length > 0 && (
              <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-2">
                {/* Root namespace types link */}
                {root.types.length > 0 && (
                  <a
                    href={`${base}/api/${root.types[0].slug}`}
                    class="group rounded-lg border border-border/50 bg-background px-4 py-3 hover:border-accent/50 hover:bg-surface-hover transition-all"
                  >
                    <div class="text-sm font-medium text-text-muted group-hover:text-accent truncate">
                      {root.name} <span class="text-[10px] opacity-50">({root.types.length})</span>
                    </div>
                  </a>
                )}
                {root.children.map((child) => (
                  <a
                    href={`${base}/api/${child.types[0]?.slug ?? child.children[0]?.types[0]?.slug}`}
                    class="group rounded-lg border border-border/50 bg-background px-4 py-3 hover:border-accent/50 hover:bg-surface-hover transition-all"
                  >
                    <div class="text-sm font-medium text-text-muted group-hover:text-accent truncate">
                      {child.name} <span class="text-[10px] opacity-50">({child.totalTypes})</span>
                    </div>
                  </a>
                ))}
              </div>
            )}

            {/* Namespaces with no children - show direct type links */}
            {root.children.length === 0 && root.types.length > 0 && (
              <div class="flex flex-wrap gap-2">
                {root.types.slice(0, 12).map((t) => (
                  <a
                    href={`${base}/api/${t.slug}`}
                    class="rounded-md border border-border/50 bg-background px-3 py-1.5 text-xs text-text-muted hover:text-accent hover:border-accent/50 transition-all"
                  >
                    {t.name}
                  </a>
                ))}
                {root.types.length > 12 && (
                  <span class="px-3 py-1.5 text-xs text-text-muted">+{root.types.length - 12} more</span>
                )}
              </div>
            )}
          </div>
        );
      })}
    </div>
  </div>
</DocsLayout>
