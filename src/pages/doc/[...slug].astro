---
import GuidesLayout from "../../layouts/GuidesLayout.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const guides = await getCollection("guides");
  const slugs = new Set(guides.map((g) => g.data.slug));

  const paths = guides
    .filter((guide) => guide.data.slug !== "index")
    .map((guide) => ({
      params: { slug: guide.data.slug },
      props: { guide, isIndex: false },
    }));

  // Generate fallback index pages for parent paths that don't have a guide
  // e.g. /doc/systems, /doc/scene, /doc/editor
  const parentPaths = new Set<string>();
  for (const g of guides) {
    const parts = g.data.slug.split("/");
    for (let i = 1; i < parts.length; i++) {
      const parent = parts.slice(0, i).join("/");
      if (!slugs.has(parent) && !parentPaths.has(parent)) {
        parentPaths.add(parent);
        const children = guides.filter((c) => c.data.slug.startsWith(parent + "/"));
        paths.push({
          params: { slug: parent },
          props: { guide: null, isIndex: true, indexSlug: parent, children },
        });
      }
    }
  }

  return paths;
}

const { guide, isIndex, indexSlug, children } = Astro.props;
const Content = guide ? (await render(guide)).Content : null;
const base = import.meta.env.BASE_URL.replace(/\/$/, "");

// Build prev/next navigation from ordered guide list
const allGuides = (await getCollection("guides"))
  .filter((g) => g.data.slug !== "index")
  .sort((a, b) => a.data.order - b.data.order);

const currentIndex = guide ? allGuides.findIndex((g) => g.data.slug === guide.data.slug) : -1;
const prevGuide = currentIndex > 0 ? allGuides[currentIndex - 1] : null;
const nextGuide = currentIndex >= 0 && currentIndex < allGuides.length - 1 ? allGuides[currentIndex + 1] : null;

const currentSlug = guide?.data?.slug || indexSlug;
const currentTitle = guide?.data?.title || (indexSlug?.split("/").pop()?.replace(/-/g, " ").replace(/\b\w/g, (c: string) => c.toUpperCase()));
const breadcrumbParts = currentSlug.split("/");
---

<GuidesLayout title={currentTitle} currentSlug={currentSlug}>
  <div data-pagefind-body>
    <!-- Breadcrumb -->
    <div class="flex items-center gap-2 text-sm text-text-muted mb-6 flex-wrap">
      <a href={`${base}/doc/`} class="hover:text-accent transition-colors">Docs</a>
      {breadcrumbParts.map((part, i) => {
        const isLast = i === breadcrumbParts.length - 1;
        const path = breadcrumbParts.slice(0, i + 1).join("/");
        const label = part.replace(/-/g, " ").replace(/\b\w/g, (c: string) => c.toUpperCase());
        return (
          <>
            <span>&rsaquo;</span>
            {isLast ? (
              <span class="text-text">{currentTitle || label}</span>
            ) : (
              <a href={`${base}/doc/${path}`} class="hover:text-accent transition-colors">{label}</a>
            )}
          </>
        );
      })}
    </div>

    <!-- Page title -->
    <h1 class="text-3xl font-bold text-accent mb-6">{currentTitle}</h1>

    {/* Regular guide page */}
    {Content && (
      <article class="prose prose-invert max-w-none">
        <Content />
      </article>
    )}

    {/* Index page — list children */}
    {isIndex && children && (
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
        {children.sort((a, b) => a.data.order - b.data.order).map((child) => (
          <a
            href={`${base}/doc/${child.data.slug}`}
            class="group block rounded-xl border border-border bg-surface p-5 hover:border-accent/50 hover:bg-surface-hover transition-all"
          >
            <h2 class="font-semibold text-text group-hover:text-accent transition-colors">
              {child.data.title}
            </h2>
          </a>
        ))}
      </div>
    )}

    <!-- Prev/Next navigation -->
    {guide && (prevGuide || nextGuide) && (
      <div class="mt-12 grid grid-cols-2 gap-4">
        {prevGuide ? (
          <a
            href={`${base}/doc/${prevGuide.data.slug}`}
            class="group flex flex-col rounded-lg border border-border bg-surface p-4 hover:border-accent/50 hover:bg-surface-hover transition-all"
          >
            <span class="text-xs text-text-muted mb-1">&larr; Previous</span>
            <span class="text-sm font-medium text-text group-hover:text-accent truncate">{prevGuide.data.title}</span>
          </a>
        ) : <div />}
        {nextGuide ? (
          <a
            href={`${base}/doc/${nextGuide.data.slug}`}
            class="group flex flex-col items-end rounded-lg border border-border bg-surface p-4 hover:border-accent/50 hover:bg-surface-hover transition-all"
          >
            <span class="text-xs text-text-muted mb-1">Next &rarr;</span>
            <span class="text-sm font-medium text-text group-hover:text-accent truncate">{nextGuide.data.title}</span>
          </a>
        ) : <div />}
      </div>
    )}

    <!-- Footer links -->
    {guide && (
      <div class="mt-12 pt-4 border-t border-border text-xs text-text-muted flex flex-wrap gap-4">
        {guide.data.source && (
          <a href={guide.data.source} class="hover:text-accent transition-colors" target="_blank" rel="noopener">
            View original on sbox.game
          </a>
        )}
        <a href={`https://github.com/RedEagleStudios/sbox-docs/blob/main/src/content/doc/${guide.data.slug}.md`} class="hover:text-accent transition-colors" target="_blank" rel="noopener">
          View on GitHub
        </a>
      </div>
    )}
  </div>
</GuidesLayout>
