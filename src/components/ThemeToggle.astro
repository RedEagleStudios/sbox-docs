---
import { Icon } from "astro-icon/components";
---

<button
  class="theme-toggle p-1.5 rounded-md text-text-muted hover:text-text hover:bg-surface-hover transition-colors"
  aria-label="Toggle theme"
>
  <Icon name="lucide:sun" class="h-5 w-5 hidden dark:block" />
  <Icon name="lucide:moon" class="h-5 w-5 block dark:hidden" />
</button>

<script>
  function applyTheme() {
    document.querySelectorAll(".theme-toggle").forEach((toggle) => toggle.addEventListener("click", () => {
      const isDark = document.documentElement.classList.contains("dark");
      if (isDark) {
        document.documentElement.classList.remove("dark");
        localStorage.setItem("theme", "light");
      } else {
        document.documentElement.classList.add("dark");
        localStorage.setItem("theme", "dark");
      }
    }));
  }
  applyTheme();
  document.addEventListener("astro:after-swap", applyTheme);
</script>
